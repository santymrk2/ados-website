# Development Dockerfile for Activados
# Uso local con docker compose

FROM node:22-alpine

WORKDIR /app

# Instalar bun para poder usar bun install
RUN npm install -g bun

# Instalar dependencias
COPY package.json bun.lock* ./
RUN bun install --frozen-lockfile

# Copiar código fuente
COPY . .

# Exponer puerto
EXPOSE 3000

# Comando para desarrollo (usamos npx para que Next.js corra sobre Node, no sobre Bun)
CMD ["npx", "next", "dev"]