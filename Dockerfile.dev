# Development Dockerfile for Activados
# Uso local con docker compose

FROM node:22-alpine

WORKDIR /app

# Instalar dependencias
COPY package.json bun.lock* ./
RUN npm install

# Copiar código fuente
COPY . .

# Exponer puerto
EXPOSE 3000

# Comando para desarrollo - usa node/npx para consistencia
CMD ["npx", "next", "dev", "--turbopack"]