# Development Dockerfile for ADOS Website.
# Used by docker compose for local development.

FROM oven/bun:1-alpine

# Node.js para ejecutar Next.js (Turbopack necesita Node runtime, no Bun)
RUN apk add --no-cache nodejs

WORKDIR /app

COPY package.json bun.lock ./
RUN bun install --frozen-lockfile

COPY . .

EXPOSE 3000

# El CMD se sobrescribe en docker-compose.override.yml
